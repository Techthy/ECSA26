  <container name="WebUi" description="WebUI for customers to buy tea"/>
  <container name="RecommenderService" description="Recomments tea products to users"/>
  <container name="ImageProvider" description="Provides Product images to WebUI and BackendUI"/>
  <container name="AuthService" description="Manages authentication and user management."/>
  <container name="ExternalAuthProvider" description="Authentication provider e.g., Keycloak"/>
  <container name="PermissionMiddleware" description="Scenario 2: Permission middleware that decides if requests are allowed"/>
  <container name="Database" description="Database that stores teastore's data"/>
  <container name="Cache" description="Cache to store Auth tokens (and scenario 1 product data)"/>
  <container name="BackendUI" description="Backend for employees to manage the teastore"/>
  <container name="PersistenceService" description="Persists data in the database."/>
  <persons name="Customer" description="Customer that buys tea"/>
  <persons name="Storeman" description="Fulfills orders."/>
  <persons name="Data-Manager" description="Maintains tea-product data."/>
  <persons name="Accountant" description="Manages invoices and payment reminder"/>
