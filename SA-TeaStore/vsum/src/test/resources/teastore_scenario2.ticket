<?xml version="1.0" encoding="UTF-8"?>
<ticket:TicketRepository xmi:version="2.0" xmlns:xmi="http://www.omg.org/XMI"
  xmlns:ticket="http://vitruv.tools/ticket">
  <tickets name="Compliance Requirement: Restrict Employee Access to Sensitive Backend Data"
    id="T-124"
    description="Due to new compliance regulations, the Teastore Backend must ensure that employees only access data that is strictly necessary for their roles. Currently, the Backend UI exposes full product, order, and invoice information to all internal user groups (Logistics, DataManagers, Finance). This violates least-privilege principles and upcoming regulatory requirements." />
  <tickets name="Revamp Product Detail Layout for Improved Readability" id="T-125"
    description="Users report that key product information is difficult to scan quickly. Redesign the product detail page layout to improve text hierarchy, spacing, and overall readability without changing underlying functionality." />
  <tickets name="Fix Incorrect Price Rounding on Checkout Page" id="T-126"
    description="Some customers experience inconsistent price rounding during checkout, leading to minor discrepancies between product pages and the final invoice. Investigate and correct the rounding logic for all currencies." />
  <tickets name="Add Support for Bulk Adding Products to Cart" id="T-127"
    description="Wholesale and business customers have requested a way to add multiple quantities or multiple tea types to the cart in one action. Implement a bulk-add interface on category and product list pages." />
  <tickets name="Resolve Occasional 500 Error When Loading Recommendations" id="T-128"
    description="The recommendation service intermittently returns a 500 error under high load, causing the product page to display an error placeholder. Identify the cause and implement proper error handling and fallback content." />
  <tickets name="Improve Accessibility of Navigation Menu" id="T-129"
    description="Accessibility audits show insufficient keyboard navigation support and missing ARIA labels on the main navigation bar. Update markup and focus handling to ensure WCAG 2.1 AA compliance." />
  <tickets name="Enhance Customer Review Moderation Workflow" id="T-130"
    description="Customer success agents report inefficiencies when moderating tea product reviews. Add filtering, bulk actions, and clearer review status indicators to streamline moderation tasks." />
  <tickets name="Fix Missing Images in Tea Category Thumbnails" id="T-131"
    description="Some tea categories intermittently show missing or broken thumbnail images due to outdated CDN references. Diagnose the issue and ensure stable loading of category images." />
  <tickets name="Implement Wish List Feature for Logged-In Users" id="T-132"
    description="Customers frequently request the ability to save teas for later. Implement a persistent wish list tied to user accounts, including UI components and backend storage support." />
  <tickets name="Display Delivery Time Estimates on Product Pages" id="T-133"
    description="Customer support indicates that unclear delivery expectations lead to frequent inquiries. Add region-based delivery time estimates directly on product pages to increase transparency." />
  <tickets name="Fix Checkout Form Autofill Validation Error" id="T-134"
    description="Autofill entries provided by browsers are sometimes rejected by the validation logic in the checkout form. Adjust validation to properly handle valid autofill values across browsers." />
</ticket:TicketRepository>