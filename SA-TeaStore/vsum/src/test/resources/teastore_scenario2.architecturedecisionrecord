<?xml version="1.0" encoding="UTF-8"?>
<architectureDecisionRecord:ADRRepository xmi:version="2.0" xmlns:xmi="http://www.omg.org/XMI" xmlns:architectureDecisionRecord="http://vitruv.tools/architectureDecisionRecord">
  <adIssues name="Introduce Role-Based Compliance Restrictions for Teastore Backend" shortName="Backend Authorization Redesign" id="ADR-283" motivation="The Teastore system must comply with regulatory requirements that restrict access to sensitive data. Different employee roles (Logistics, DataManager, Finance) should only see the data necessary for their tasks. The current backend exposes too much data, therefore fine-grained role-based authorization must be introduced." recommendation="Introduce an authorization mechanism that can enforce fine-grained permissions while avoiding overload to critical services, especially the AuthService." backgroundReading="Regulatory compliance specifications, Microservice authorization design patterns, Keycloak Authorization Services documentation" ticketID="T-124">
    <role name="Software Architect" id="ARCH-1"/>
    <isSolvedBy name="Permissions Middleware with Centralized Policy Service" description="A standalone Permissions Middleware intercepts all Backend UI requests, validates tokens by calling the AuthService, retrieves role information from AuthService, and evaluates permissions against a local policy database." pros="Centralized, unified authorization logic, Clear separation of concerns, Easy to support complex policy-based access models and auditing" cons="Possibly increased load on Auth Service, Increased latency, Introduces a new single point of failure, Requires autoscaling and aggressive caching to remain viable" knownUses="Legacy enterprise architectures using OAuth2 token introspection, Systems with centralized PDP/PIP infrastructure" backgroundReading="NIST Access Control Models, Centralized PDP architecture, OAuth2 Token Introspection">
      <impacts referencedQualifiedName="AuthService">
        <referencedObject href="teastore_scenario2.c2#//@container.3"/>
      </impacts>
      <impacts referencedQualifiedName="BackendUI">
        <referencedObject href="teastore_scenario2.c2#//@container.8"/>
      </impacts>
    </isSolvedBy>
    <isSolvedBy name="RBAC Using AuthService/Keycloak with JWT Embedded Roles" description="Roles are assigned via AuthService (e.g., Keycloak). These roles are embedded into JWT tokens as claims. All microservices validate JWTs locally without contacting AuthService. Authorizations are enforced inside each service." pros="Highly scalable, No additional load on AuthService, Local authorization is fast and reliable, Aligns well with microservice autonomy" cons="Services must be updated to interpret JWT role claims, Permission changes require token refresh, Less dynamic than policy-driven solutions" knownUses="Modern cloud-native authorization with Keycloak, Auth0, AWS Cognito, Azure AD" backgroundReading="JWT RFC7519, Keycloak Authorization Services, OAuth2 Resource Server Patterns">
      <impacts referencedQualifiedName="BackendUI" additionalInformation="Must interpret JWT claims for access control.">
        <referencedObject href="teastore_scenario2.c2#//@container.8"/>
      </impacts>
      <impacts referencedQualifiedName="PersistenceService" additionalInformation="Must enforce role-based restrictions for product, order, and invoice data.">
        <referencedObject href="teastore_scenario2.c2#//@container.9"/>
      </impacts>
    </isSolvedBy>
    <isSolvedBy name="Backend-Service Internal Role and Permission Management" description="Permissions and role mappings are stored in the Persistence or Backend service database. Backend UI forwards the user ID, and the Backend service performs authorization checks via database queries. AuthService is only used for authentication." pros="Simple implementation, No additional load on AuthService, Permissions can change dynamically without token rotation" cons="Poor scalability under high load, Authorization logic tightly coupled to Backend services, Violates microservice autonomy, Database becomes a bottleneck" knownUses="Monolithic applications, Systems without external authorization infrastructure" backgroundReading="RBAC/ACL in relational systems, Access control via database tables">
      <impacts referencedQualifiedName="PersistenceService" additionalInformation="Must store permission tables and perform additional authorization queries.">
        <referencedObject href="teastore_scenario2.c2#//@container.9"/>
      </impacts>
      <impacts referencedQualifiedName="BackendUI" additionalInformation="Must provide user identity to backend for permission evaluation.">
        <referencedObject href="teastore_scenario2.c2#//@container.8"/>
      </impacts>
    </isSolvedBy>
    <hasOutcome name="Use Centralized Permissions Middleware for Authorization" status="In Implementation" justification="Centralizing authorization in a dedicated Permissions Middleware allows the system to enforce uniform access control across all BackendUI requests—even as policy complexity grows. This approach aligns with established enterprise architectures and makes auditing, governance, and policy evolution easier. Although it introduces latency and operational dependencies, these concerns can be mitigated with caching, horizontal scaling, and resilient deployment practices. The central policy point provides long-term maintainability and reduces duplication of authorization logic in individual services." assumptions="The AuthService is capable of reliably providing token introspection and role information at scale. Policy rules can be maintained centrally and updated without requiring redeployment of dependent services. Network latency between BackendUI → Permissions Middleware → AuthService is acceptable or mitigated by caching. All Backend UI requests can be routed through the Permissions Middleware without architectural constraints. The organization prefers a single, unified point for access control enforcement rather than distributed checks. The Permissions Middleware can be deployed redundantly to avoid becoming a hard single point of failure.&#xA;" consequences="Authorization becomes centralized and consistent. Introduces a critical single point of failure in the request flow." chooses="//@adIssues.0/@isSolvedBy.0" decisionStatus="ACCEPTED"/>
  </adIssues>
</architectureDecisionRecord:ADRRepository>
